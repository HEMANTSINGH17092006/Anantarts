{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(css|images|uploads)/(.+)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/payment-recovery",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/process-jobs",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/daily-reconciliation",
      "schedule": "0 2 * * *"
    }
  ]
}
