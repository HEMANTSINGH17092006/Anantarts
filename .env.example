# ==========================================
# ANANT ARTS - ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================

# 1. Supabase PostgreSQL Direct Connection Pooler URI
# Used for backend database queries and migrations.
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# 2. Supabase API Public Access Credentials
# Used by the browser client to request products, reviews, and logs.
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REFERENCE].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# 3. Supabase Administrative Keys (Service Role)
# Used exclusively on the server to bypass Row Level Security (RLS) for checkout orders and admin updates.
# WARNING: Keep this secret secure! Never expose this on the client side.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# 4. Admin Session Encryption Secret (JWT)
# A secure, random string used by 'jose' to sign and verify administrative session cookies.
# Default fallback: 'anant_arts_divine_key_999'
JWT_SECRET="generate_a_secure_long_random_string_here"
