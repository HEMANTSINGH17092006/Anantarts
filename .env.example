# ==========================================
# ANANT ARTS - PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================
# Copy this file to .env.local for local development.
# For production, add all variables to Vercel Environment Variables Dashboard.

# ==========================================
# SITE / DOMAIN CONFIGURATION
# ==========================================

# Production site URL — no trailing slash
NEXT_PUBLIC_SITE_URL="https://anantarts.in"

# ==========================================
# SUPABASE CONFIGURATION
# ==========================================

# 1. Supabase PostgreSQL Direct Connection Pooler URI
# Used for backend database queries and migrations.
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# 2. Supabase API Public Access Credentials
# Used by the server-side db-helpers to fetch products, categories, banners etc.
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REFERENCE].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# 3. Supabase Administrative Keys (Service Role)
# Used exclusively on the server side in admin server actions and API routes.
# WARNING: NEVER expose this on the client side or commit to git!
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================

# 4. Admin Session Encryption Secret (JWT)
# A secure, random string used by 'jose' to sign and verify admin session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="generate_a_secure_long_random_string_here_minimum_32_chars"

# ==========================================
# PAYMENT GATEWAY — RAZORPAY
# ==========================================

# 5. Razorpay API Keys
# Get these from https://dashboard.razorpay.com/ → API Keys
# Use test keys (rzp_test_xxx) for staging, live keys (rzp_live_xxx) for production.
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_YOUR_KEY_ID_HERE"
RAZORPAY_KEY_SECRET="YOUR_RAZORPAY_KEY_SECRET_HERE"

# ==========================================
# ANALYTICS & MONITORING
# ==========================================

# 6. Google Analytics 4 Measurement ID (from GA4 → Admin → Data Streams)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# 7. Microsoft Clarity Project ID (from clarity.microsoft.com → Settings)
NEXT_PUBLIC_CLARITY_PROJECT_ID="your_clarity_project_id"

# 8. Google Search Console Verification Meta Tag content value
NEXT_PUBLIC_GSC_VERIFICATION="your-gsc-verification-code"
